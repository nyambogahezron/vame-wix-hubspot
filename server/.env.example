# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/vame-wix-hubspot

# Server Config
APP_PORT=3001
APP_CLIENT_ORIGIN=http://localhost:3000
APP_AUTH_BASE_URL=http://localhost:3001

# Better Auth
BETTER_AUTH_SECRET=your_better_auth_secret_here
BETTER_AUTH_URL=http://localhost:3001

# Wix Credentials
WIX_APP_ID=your_wix_app_id
WIX_APP_SECRET=your_wix_app_secret
WIX_PUBLIC_KEY=your_wix_public_key

# HubSpot Credentials
HUBSPOT_CLIENT_ID=your_hubspot_client_id
HUBSPOT_CLIENT_SECRET=your_hubspot_client_secret
HUBSPOT_REDIRECT_URI=http://localhost:3001/api/integration/hubspot/callback
HUBSPOT_DEVELOPER_API_KEY=your_hubspot_developer_api_key
